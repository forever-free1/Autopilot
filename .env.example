# 基础设施
MYSQL_DATABASE=autopilot
MYSQL_USER=autopilot
MYSQL_PASSWORD=autopilot_dev
MYSQL_ROOT_PASSWORD=root_dev
RABBITMQ_USER=autopilot
RABBITMQ_PASSWORD=autopilot_dev

# 服务端口
BACKEND_PORT=8080
AGENT_PORT=8000
WEB_PORT=5173
JWT_SECRET=replace-with-a-long-random-secret
INTERNAL_TOKEN=replace-with-a-random-internal-token

# RAG：默认 mock 可直接演示；切换 ragflow 时填写下面三项
RAG_PROVIDER=mock
RAGFLOW_BASE_URL=http://host.docker.internal:9380
RAGFLOW_API_KEY=
RAGFLOW_DATASET_IDS=
